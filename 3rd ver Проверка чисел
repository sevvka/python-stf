print('Первое число')
a = input()
print('Действие')
b = input()
print('Второе число')
c = input()

try: #команда для проверки, без принудительной остановки программы
    a = int(a)
    c = int(c)
except ValueError: #Если написаны не числа, программа останавливает свою работу
    print('значения выбраны некорректно, пример не может быть составлен')
    exit()    

if b == '+':
    result = a + c
    
elif b == '-':
    result = a - c

elif b == '*':
    result = a * c

elif b == '/':
    result = a / c

else:
    result = 'Не может быть определен из-за некорректности написания примера'

print('Ваш ответ:', result)
