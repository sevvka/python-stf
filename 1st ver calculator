print('Первое число')
a = input()
print('Действие')
b = input()
print('Второе число')
c = input() #Создание примера (Первое число, действие, второе число)


a = int(a) #преобразование введенных данных в переменные, с которыми можно будет в дальнейшем проводить действия
c = int(c)

if b == '+':
    result = a + c #Варианты при различных действиях
    
elif b == '-':
    result = a - c

elif b == '*':
    result = a * c

elif b == '/':
    result = a / c

else:
    result = 'Не может быть определен из-за некорректности написания примера'

